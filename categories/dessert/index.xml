    <item>
      <title>Bananenkuchen</title>
      <link>https://john4web.github.io/cook/docs/bananenkuchen/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://john4web.github.io/cook/docs/bananenkuchen/</guid>
      <description>&lt;h2 id=&#34;-kategorie&#34;&gt;📁 Kategorie&lt;/h2&gt;
&lt;p&gt;Dessert&lt;/p&gt;
&lt;h2 id=&#34;zutaten&#34;&gt;🗒️Zutaten&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;150g Haferflocken&lt;/li&gt;
&lt;li&gt;1 TL Backpulver&lt;/li&gt;
&lt;li&gt;50g Erdnussbutter&lt;/li&gt;
&lt;li&gt;1 Banane (ca. 180g)&lt;/li&gt;
&lt;li&gt;200ml Alpro Sojamilch (Himmlischer Vanillegeschmack)&lt;/li&gt;
&lt;li&gt;1 Prise Salz&lt;/li&gt;
&lt;li&gt;1/2 TL Zimt&lt;/li&gt;
&lt;li&gt;100g Heidelbeeren&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id=&#34;-zubereitung&#34;&gt;🔪 Zubereitung&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;Haferflocken mahlen&lt;/li&gt;
&lt;li&gt;Banane zerdrücken&lt;/li&gt;
&lt;li&gt;alles in Schale geben und mixen&lt;/li&gt;
&lt;li&gt;In der Mikrowelle 6 Minuten lang &amp;ldquo;backen&amp;rdquo;&lt;/li&gt;
&lt;li&gt;Mit Zimt und Heidelbeeren bestreuen&lt;/li&gt;
&lt;li&gt;Genießen!&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id=&#34;-nährwerte&#34;&gt;⚖️ Nährwerte&lt;/h2&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;Makro&lt;/th&gt;
          &lt;th style=&#34;text-align: right&#34;&gt;Anteil&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;Kalorien&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;1177.20 kcal&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Fett&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;37.95 g&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;davon ges. Fett&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;5.30 g&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Carbs&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;157.00 g&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;davon Zucker&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;45.40 g&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Ballaststoffe&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;22.50 g&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Protein&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;44.60 g&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Salz&lt;/td&gt;
          &lt;td style=&#34;text-align: right&#34;&gt;0.61 g&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h2 id=&#34;-zubereitungszeit&#34;&gt;⏰ Zubereitungszeit&lt;/h2&gt;
&lt;p&gt;ca. 15 Minuten&lt;/p&gt;</description>
